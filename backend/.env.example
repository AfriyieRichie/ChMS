# Copy this to .env and fill in values.
# Generate DJANGO_SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Docker service names are used as hostnames inside the compose network.
# For local-only (no Docker) use localhost for both.
DATABASE_URL=postgres://chms:chms_dev@postgres:5432/chms
REDIS_URL=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

DEFAULT_TIMEZONE=Africa/Accra
DEFAULT_CURRENCY=GHS

# Deferred integrations — leave as "console" for now
SMS_PROVIDER=console
EMAIL_PROVIDER=console
PAYMENT_PROVIDER=console
